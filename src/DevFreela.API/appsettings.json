{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithMachineName" ]
  },
  "Jwt": {
    "Key": "REPLACE_WITH_YOUR_SUPER_SECRET_KEY",
    "Issuer": "DevFreela.API",
    "Audience": "DevFreela.App"
  },
  "AllowedHosts": "*",
  "FreelanceTotalCostConfig": {
    "Minimum": 1000,
    "Maximum": 999999
  },
  "ConnectionStrings": {
    "DevFreelaCs": "Server=localhost\\SQLSERVER17_DEV;Database=DevFreelaDb;Trusted_Connection=True;trustServerCertificate=true"
  },
  "SendGrid": {
    "ApiKey": "REPLACE_WITH_YOUR_SENDGRID_API_KEY",
    "FromEmail": "no-reply@devfreela.com",
    "FromName": "DevFreela"
  }
}
